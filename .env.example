# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# --- Required ---
# Web search/fetch run server-side through the Anthropic API, so this is the
# only key Maxim needs. (No Tavily/SerpAPI/Brave — search is not a separate service.)
ANTHROPIC_API_KEY=

# --- Optional (M2 custom tools; everything degrades gracefully without them) ---
# Deeper paper search via Semantic Scholar.
SEMANTIC_SCHOLAR_API_KEY=
# GitHub issues/discussions signal for the community researcher.
GITHUB_TOKEN=
